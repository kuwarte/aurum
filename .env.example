# Aurum Dev 2 environment variables.
# Placeholder values only. Do not commit real private keys, API keys, or funded
# account details. The MVP deployment target is Casper testnet only.

# ---------------------------------------------------------------------------
# Build-only defaults
# ---------------------------------------------------------------------------

# fixed
CASPER_RPC_URL=https://node.testnet.cspr.cloud/rpc

# fixed
CASPER_NETWORK_NAME=casper-test

# fixed
CASPER_DEPLOY_CHAIN_NAME=casper-test

# edit in local .env only
# Preferred: path to a local PEM file. Do not commit keys/ or *.pem.
CASPER_PRIVATE_KEY_PATH=./keys/deployer/secret_key.pem

# discouraged fallback only; leave empty when CASPER_PRIVATE_KEY_PATH is set.
CASPER_PRIVATE_KEY=

# edit
CASPER_PUBLIC_KEY=01_replace_with_testnet_public_key

# edit
CASPER_ACCOUNT_HASH=account-hash-replace-with-testnet-account


# ---------------------------------------------------------------------------
# Testnet deployment values
# ---------------------------------------------------------------------------

# fixed
CASPER_EXPECTED_CONTRACTS=credit_registry,compliance_registry,oracle_paywall,reputation_registry

# leave as placeholder first, edit after successful deployment
CREDIT_REGISTRY_DEPLOY_HASH=deploy-hash-todo-credit-registry

# leave as placeholder first, edit after successful deployment
COMPLIANCE_REGISTRY_DEPLOY_HASH=deploy-hash-todo-compliance-registry

# leave as placeholder first, edit after successful deployment
ORACLE_PAYWALL_DEPLOY_HASH=deploy-hash-todo-oracle-paywall

# leave as placeholder first, edit after successful deployment
REPUTATION_REGISTRY_DEPLOY_HASH=deploy-hash-todo-reputation-registry

# leave as placeholder first, edit after deploy confirmation
CREDIT_REGISTRY_HASH=hash-todo-credit-registry

# leave as placeholder first, edit after deploy confirmation
COMPLIANCE_REGISTRY_HASH=hash-todo-compliance-registry

# leave as placeholder first, edit after deploy confirmation
ORACLE_PAYWALL_HASH=hash-todo-oracle-paywall

# leave as placeholder first, edit after deploy confirmation
REPUTATION_REGISTRY_HASH=hash-todo-reputation-registry


# ---------------------------------------------------------------------------
# x402 configuration
# ---------------------------------------------------------------------------

# fixed for MVP
X402_MODE=mock

# leave placeholder unless your team has live facilitator
X402_FACILITATOR_URL=https://todo-facilitator.example

# edit
# For MVP, you can use the same value as CASPER_ACCOUNT_HASH.
X402_TREASURY_ACCOUNT=account-hash-replace-with-testnet-treasury

# fixed unless your team changes the query price
X402_QUERY_PRICE_CSPR=1.50

# fixed
X402_NETWORK=casper-test

# Required for POST /cron/monitor. Use a long random value in local/host env.
CRON_SECRET=replace-with-random-cron-secret

# Optional cache-aside TTL for costly Casper getter deploy reads.
CASPER_GETTER_CACHE_TTL_SECONDS=300

# Optional LLM fallback controls. For fast local demos, override in .env with:
# LLM_FAST_FALLBACK=true
# LLM_MAX_RETRIES=0
# LLM_RETRY_DELAY_SECONDS=0
LLM_FAST_FALLBACK=false
LLM_MAX_RETRIES=2
LLM_RETRY_DELAY_SECONDS=1


# ---------------------------------------------------------------------------
# CSPR.cloud configuration
# ---------------------------------------------------------------------------

# edit
# Use "mock" if you do not have a CSPR.cloud key yet.
# Use "live" if you already have a valid CSPR.cloud key.
CSPR_CLOUD_MODE=mock

# edit if CSPR_CLOUD_MODE=live
# Leave placeholder or empty if using mock.
CSPR_CLOUD_KEY=replace-with-cspr-cloud-api-key

# fixed
CSPR_CLOUD_BASE_URL=https://api.testnet.cspr.cloud

# fixed
CSPR_CLOUD_STREAMING_URL=wss://streaming.testnet.cspr.cloud

# fixed
CSPR_NODE_RPC_URL=https://node.testnet.cspr.cloud

# fixed
CSPR_NODE_SSE_URL=https://node-sse.testnet.cspr.cloud

# leave empty unless Codex/dev docs gave exact CSPR.cloud route templates
CSPR_CLOUD_WALLET_ACTIVITY_PATH=

# leave empty unless Codex/dev docs gave exact CSPR.cloud route templates
CSPR_CLOUD_DEFI_POSITIONS_PATH=

# leave empty unless Codex/dev docs gave exact CSPR.cloud route templates
CSPR_CLOUD_LOANS_PATH=

# leave empty unless Codex/dev docs gave exact CSPR.cloud route templates
CSPR_CLOUD_REPAYMENTS_PATH=

# leave empty unless Codex/dev docs gave exact CSPR.cloud route templates
CSPR_CLOUD_YIELD_PATH=

# leave empty unless Codex/dev docs gave exact CSPR.cloud route templates
CSPR_CLOUD_RWA_PATH=
