# =============================================================================
# AURUM PROTOCOL — API Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase  (https://supabase.com → Settings → API)
# Use the service_role key, NOT the anon key.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key


# -----------------------------------------------------------------------------
# Groq API  (https://console.groq.com → API Keys)
# Two keys supported for load balancing across agents.
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_your_primary_key
GROQ_API_KEY_1=gsk_your_secondary_key


# -----------------------------------------------------------------------------
# CSPR.cloud API  (https://cspr.cloud → API Keys)
# Base URL uses testnet endpoint. Switch to https://api.cspr.cloud for mainnet.
# -----------------------------------------------------------------------------
CSPR_CLOUD_MODE=mock
# mock = deterministic fake wallet data (safe for demos, no API key needed)
# live = real on-chain data from CSPR.cloud

CSPR_CLOUD_KEY=your-cspr-cloud-api-key
CSPR_CLOUD_BASE_URL=https://api.testnet.cspr.cloud


# -----------------------------------------------------------------------------
# Casper Network Configuration
# -----------------------------------------------------------------------------
CASPER_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
CASPER_DEPLOY_CHAIN_NAME=casper-test
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test
CASPER_NETWORK=testnet

# Path to casper-client binary (if not on PATH)
# Example: /home/youruser/.cargo/bin/casper-client
CASPER_CLIENT_BIN=casper-client


# -----------------------------------------------------------------------------
# Deployer Account
# The deployer account is the admin caller for all contract entrypoints.
# CASPER_PRIVATE_KEY_PATH can be relative: ../keys/deployer/secret_key.pem
# -----------------------------------------------------------------------------
CASPER_PRIVATE_KEY=../keys/deployer/secret_key.pem
CASPER_PRIVATE_KEY_PATH=../keys/deployer/secret_key.pem
CASPER_PUBLIC_KEY=01your_deployer_public_key_hex
CASPER_ACCOUNT_HASH=account-hash-your_deployer_account_hash


# -----------------------------------------------------------------------------
# Agent Keypairs  (generate with: scripts/deploy/gen-agent-keys.sh)
# Each agent uses a separate key for signing.
# -----------------------------------------------------------------------------
ATTESTATION_AGENT_PUBLIC_KEY=01your_attestation_agent_public_key
ATTESTATION_AGENT_PRIVATE_KEY_PATH=../keys/attestation/secret_key.pem

MONITORING_AGENT_PUBLIC_KEY=01your_monitoring_agent_public_key
MONITORING_AGENT_PRIVATE_KEY_PATH=../keys/monitoring/secret_key.pem

RISK_AGENT_PUBLIC_KEY=01your_risk_agent_public_key
RISK_AGENT_PRIVATE_KEY_PATH=../keys/risk/secret_key.pem

FRAUD_AGENT_PUBLIC_KEY=01your_fraud_agent_public_key
FRAUD_AGENT_PRIVATE_KEY_PATH=../keys/fraud/secret_key.pem

LENDING_AGENT_PUBLIC_KEY=01your_lending_agent_public_key
LENDING_AGENT_PRIVATE_KEY_PATH=../keys/lending/secret_key.pem


# -----------------------------------------------------------------------------
# Deployed Contract Hashes  (fill after running scripts/deploy/deploy-contracts.sh)
#
# Two hash types per contract:
#   HASH             = package hash (hash- prefix)   — used for versioned lookups
#   CONTRACT_HASH    = callable hash (contract- prefix) — used for put-deploy calls
#
# Both are output by the deploy script. CONTRACT_HASH is preferred by the Python layer.
# -----------------------------------------------------------------------------

# CreditRegistry
CREDIT_REGISTRY_HASH=hash-your_credit_registry_package_hash
CREDIT_REGISTRY_CONTRACT_HASH=contract-your_credit_registry_callable_hash
CREDIT_REGISTRY_DEPLOY_HASH=your_credit_registry_deploy_hash

# ComplianceRegistry
COMPLIANCE_REGISTRY_HASH=hash-your_compliance_registry_package_hash
COMPLIANCE_REGISTRY_CONTRACT_HASH=contract-your_compliance_registry_callable_hash
COMPLIANCE_REGISTRY_DEPLOY_HASH=your_compliance_registry_deploy_hash

# OraclePaywall
ORACLE_PAYWALL_HASH=hash-your_oracle_paywall_package_hash
ORACLE_PAYWALL_CONTRACT_HASH=contract-your_oracle_paywall_callable_hash
ORACLE_PAYWALL_DEPLOY_HASH=your_oracle_paywall_deploy_hash

# ReputationRegistry
REPUTATION_REGISTRY_HASH=hash-your_reputation_registry_package_hash
REPUTATION_REGISTRY_CONTRACT_HASH=contract-your_reputation_registry_callable_hash
REPUTATION_REGISTRY_DEPLOY_HASH=your_reputation_registry_deploy_hash


# -----------------------------------------------------------------------------
# x402 Payment Gate  (oracle query payment verification)
# -----------------------------------------------------------------------------
X402_MODE=mock
# mock = proof accepted on structure alone (no real CSPR needed, use for dev)
# live = structure check + on-chain CSPR transfer verification required

# Treasury account that receives query payments (usually the deployer account)
X402_TREASURY_ACCOUNT=account-hash-your_treasury_account_hash

# Query price
X402_QUERY_PRICE_CSPR=1.50
ORACLE_PAYWALL_QUERY_PRICE_MOTES=1500000000

X402_NETWORK=casper-test

# Required for POST /cron/monitor. Use a long random value in local/host env.
CRON_SECRET=replace-with-random-cron-secret

# Optional cache-aside TTL for costly Casper getter deploy reads.
CASPER_GETTER_CACHE_TTL_SECONDS=300


# -----------------------------------------------------------------------------
# Deploy Mode
# -----------------------------------------------------------------------------
AURUM_DEPLOY_MODE=mock
# mock = build contract call envelopes only, nothing sent to blockchain
# live = submit real put-deploy transactions to Casper testnet
