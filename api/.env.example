# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Groq API (for LLM agents)
GROQ_API_KEY=gsk_...
GROQ_API_KEY_1=gsk_...

# CSPR.cloud API — get from https://cspr.cloud
CSPR_CLOUD_KEY=your-api-key
CSPR_CLOUD_API_URL=https://api.cspr.cloud/v1

# Casper Network
CASPER_NETWORK=testnet
CASPER_NODE_URL=https://rpc.testnet.casperlabs.io
CASPER_CHAIN_NAME=casper-test

# Casper Wallet - Deployer Account
CASPER_PUBLIC_KEY=0202...
CASPER_ACCOUNT_HASH=account-hash-...
CASPER_PRIVATE_KEY_PATH=

# Agent Keypairs (Generate separate keys for each agent)
ATTESTATION_AGENT_PUBLIC_KEY=0202...
ATTESTATION_AGENT_PRIVATE_KEY_PATH=
MONITORING_AGENT_PUBLIC_KEY=0202...
MONITORING_AGENT_PRIVATE_KEY_PATH=

# Contract Hashes (Fill after deployment)
CREDIT_REGISTRY_HASH=hash-...
COMPLIANCE_REGISTRY_HASH=hash-...
ORACLE_PAYWALL_HASH=hash-...
REPUTATION_REGISTRY_HASH=hash-...

# Contract Package Hashes (Fill after deployment)
CREDIT_REGISTRY_PACKAGE_HASH=hash-...
COMPLIANCE_REGISTRY_PACKAGE_HASH=hash-...
ORACLE_PAYWALL_PACKAGE_HASH=hash-...
REPUTATION_REGISTRY_PACKAGE_HASH=hash-...
